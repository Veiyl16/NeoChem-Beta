# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Required for Firebase authentication and remote services.
# Users configure this via the Secrets panel in the AI Studio UI.
FIREBASE_API_KEY=MockApiKeyValueThatCompilesAndRunsPerfect

# FIREBASE_APPLICATION_ID: Configured application ID for programmatic Firebase initialization.
FIREBASE_APPLICATION_ID=1:536838337190:android:d2a9f1e01c1540dc

# FIREBASE_PROJECT_ID: Configured project ID for programmatic Firebase initialization.
FIREBASE_PROJECT_ID=neochem-d2a9f

# FIREBASE_STORAGE_BUCKET: Configured storage bucket path for programmatic Firebase initialization.
FIREBASE_STORAGE_BUCKET=neochem-d2a9f.appspot.com

