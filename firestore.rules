rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the document belongs to the authenticated user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // USERS COLLECTION RULES
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only owner can register or modify their own basic profile info
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Users cannot be deleted from client side
    }

    // USER PROGRESS COLLECTION RULES
    match /user_progress/{userId} {
      allow read, write: if isOwner(userId);
    }

    // LEADERBOARD COLLECTION RULES - Read-only from client, modified securely on sync
    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // GLOBAL METADATA (Read-Only Collections for regular users)
    match /materials/{document} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin-only/Server seed
    }

    match /quizzes/{document} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin-only/Server seed
    }

    match /achievements/{document} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin-only
    }

    match /periodic_elements/{document} {
      allow read: if isAuthenticated();
      allow write: if false; // Read-only seed
    }

    match /daily_rewards/{document} {
      allow read: if isAuthenticated();
      allow write: if false; // Read-only
    }
  }
}
